<Window x:Class="POEPART2YEAR2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Cybersecurity Awareness Bot"
    Height="600"
    Width="900"
    Background="#1E1E1E">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#00A8E8"
            CornerRadius="10"
            Padding="15"
            Margin="0,0,0,10">

            <StackPanel>

                <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

                <TextBlock Text="Stay Safe Online"
                       FontSize="16"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            </StackPanel>
        </Border>

        <!-- CHAT AREA -->
        <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto">

            <TextBox x:Name="ChatDisplay"
                 FontSize="15"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Background="#2D2D30"
                 Foreground="White"
                 BorderThickness="0"
                 Padding="10"/>
        </ScrollViewer>

        <!-- INPUT AREA -->
        <Grid Grid.Row="2"
          Margin="0,10,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInput"
                 Height="40"
                 FontSize="14"
                 VerticalContentAlignment="Center"
                 Padding="10"/>

            <Button Grid.Column="1"
                Content="Send"
                Margin="10,0,0,0"
                FontSize="14"
                FontWeight="Bold"
                Background="#00A8E8"
                Foreground="White"
                Click="SendButton_Click"/>

        </Grid>

    </Grid>
</Window>